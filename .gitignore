# PlatformIO build output and IDE files
.pio/
.vscode/

# Sensitive credentials — never commit
include/secrets.h

# Compiled binaries and map files
*.bin
*.elf
*.map

# Release binaries committed to docs/ for the GitHub Pages web installer
!docs/merged-firmware.bin
!docs/littlefs.bin

# JSON files in docs/ (manifest.json) are always tracked
!docs/*.json
